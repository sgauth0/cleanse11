<UserControl x:Class="Cleanse11.Views.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="📦 Components" Style="{StaticResource HeadingAccentStyle}"/>
            <TextBlock Text="Remove Windows packages and disable optional features from the mounted image."
                       Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource DangerBannerStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Removing system components may break Windows. Only remove what you know is safe."
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource InfoBannerStyle}" Margin="0,12,0,0"
                Visibility="{Binding ShowMountHint, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Load and mount an image in the Image section first, then click Load Components."
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Grid Grid.Row="3" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🔄 Load Components" Command="{Binding LoadCommand}" Padding="16,8"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0">
                <RadioButton Content="Packages" IsChecked="{Binding ShowFeatures, Converter={StaticResource InverseBoolConverter}}"
                             GroupName="Type" VerticalAlignment="Center"/>
                <RadioButton Content="Features" IsChecked="{Binding ShowFeatures}"
                             GroupName="Type" Margin="14,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Preset:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                <ComboBox ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="Name"
                          Width="160" VerticalAlignment="Center"/>
                <Button Content="Apply Preset" Command="{Binding ApplyPresetCommand}"
                        Padding="14,6" Margin="8,0,0,0" FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="16,0,0,0">
                <TextBlock Text="Safety:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource ForegroundMutedBrush}"/>
                <Border Width="10" Height="10" CornerRadius="5" Background="#6BCFAD" ToolTip="Safe"/>
                <TextBlock Text="Safe" FontSize="10" Margin="4,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource ForegroundMutedBrush}"/>
                <Border Width="10" Height="10" CornerRadius="5" Background="#FFD700" ToolTip="Caution"/>
                <TextBlock Text="Caution" FontSize="10" Margin="4,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource ForegroundMutedBrush}"/>
                <Border Width="10" Height="10" CornerRadius="5" Background="#E85C7A" ToolTip="Dangerous"/>
                <TextBlock Text="Dangerous" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource ForegroundMutedBrush}"/>
            </StackPanel>

            <TextBox Grid.Column="4" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Width="160" VerticalAlignment="Center" ToolTip="Search..."/>
        </Grid>

        <!-- Packages / Features DataGrid -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <!-- Packages -->
                <DataGrid ItemsSource="{Binding Components}"
                          SelectedItem="{Binding SelectedComponent}"
                          Visibility="{Binding ShowPackages, Converter={StaticResource BoolToVisibilityConverter}}"
                          AutoGenerateColumns="False" IsReadOnly="False"
                          SelectionMode="Single" CanUserAddRows="False"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          CanUserResizeColumns="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="10" Height="10" CornerRadius="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFD700"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Safety}" Value="Safe">
                                                        <Setter Property="Background" Value="#6BCFAD"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Safety}" Value="Dangerous">
                                                        <Setter Property="Background" Value="#E85C7A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ToolTip>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Caution"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Safe">
                                                                <Setter Property="Text" Value="Safe"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Dangerous">
                                                                <Setter Property="Text" Value="Dangerous"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border.ToolTip>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Package Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding ReleaseType}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding State}" Width="90" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Features -->
                <DataGrid ItemsSource="{Binding Features}"
                          SelectedItem="{Binding SelectedFeature}"
                          Visibility="{Binding ShowFeatures, Converter={StaticResource BoolToVisibilityConverter}}"
                          AutoGenerateColumns="False" IsReadOnly="False"
                          SelectionMode="Single" CanUserAddRows="False"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          CanUserResizeColumns="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="10" Height="10" CornerRadius="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFD700"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Safety}" Value="Safe">
                                                        <Setter Property="Background" Value="#6BCFAD"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Safety}" Value="Dangerous">
                                                        <Setter Property="Background" Value="#E85C7A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Feature Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding State}" Width="120" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Action Bar -->
        <Grid Grid.Row="5" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Select All" Command="{Binding SelectAllCommand}" Padding="14,8"/>
                <Button Content="Clear" Command="{Binding ClearAllCommand}" Margin="8,0,0,0" Padding="14,8"/>
            </StackPanel>

            <ProgressBar Grid.Column="1" IsIndeterminate="{Binding IsBusy}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="16,0" VerticalAlignment="Center" Height="4" Width="120"/>

            <TextBlock Grid.Column="2" Text="{Binding Status}"
                       VerticalAlignment="Center"
                       Margin="16,0"
                       Foreground="{StaticResource ForegroundMutedBrush}"/>

            <Button Grid.Column="3" Content="🗑️ Remove Selected" Command="{Binding RemovePackageCommand}"
                    Style="{StaticResource DangerButtonStyle}" Padding="14,8"/>
        </Grid>
    </Grid>
</UserControl>
