<UserControl x:Class="Cleanse11.Views.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="📦 Components" Style="{StaticResource HeadingAccentStyle}"/>
            <TextBlock Text="Remove Windows packages from the mounted image to slim it down."
                       Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Mount hint -->
        <Border Grid.Row="1" Style="{StaticResource InfoBannerStyle}" Margin="0,0,0,12"
                Visibility="{Binding ShowMountHint, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Mount an image in the Image section first — components will load automatically."
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Preset -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Preset:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                <ComboBox ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="Name"
                          Width="160" VerticalAlignment="Center"/>
                <Button Content="⚡ Apply &amp; Remove All"
                        Command="{Binding ApplyPresetAndRemoveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="14,8" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Right: search + count -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Width="180" VerticalAlignment="Center"
                         ToolTip="Search packages..."/>
            </StackPanel>
        </Grid>

        <!-- Packages DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Components}"
                      AutoGenerateColumns="False" IsReadOnly="False"
                      SelectionMode="Single" CanUserAddRows="False"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      CanUserResizeColumns="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="36">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="10" Height="10" CornerRadius="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFD700"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Safety}" Value="Safe">
                                                    <Setter Property="Background" Value="#6BCFAD"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Safety}" Value="Dangerous">
                                                    <Setter Property="Background" Value="#E85C7A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Package Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding ReleaseType}" Width="90" IsReadOnly="True"/>
                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="90" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Action Bar -->
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Select All" Command="{Binding SelectAllCommand}" Padding="14,8"/>
                <Button Content="Clear" Command="{Binding ClearAllCommand}" Margin="8,0,0,0" Padding="14,8"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource ForegroundMutedBrush}">
                    <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                    <Run Text="selected"/>
                </TextBlock>
            </StackPanel>

            <ProgressBar Grid.Column="2" IsIndeterminate="{Binding IsBusy}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                         VerticalAlignment="Center" Height="4" Margin="16,0"/>

            <TextBlock Grid.Column="2" Text="{Binding Status}"
                       VerticalAlignment="Center" Margin="16,0"
                       Foreground="{StaticResource ForegroundMutedBrush}"
                       TextWrapping="Wrap"/>

            <Button Grid.Column="3" Content="🗑️ Remove Selected"
                    Command="{Binding RemoveSelectedCommand}"
                    Style="{StaticResource DangerButtonStyle}" Padding="18,10"/>
        </Grid>
    </Grid>
</UserControl>
