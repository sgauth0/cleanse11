<UserControl x:Class="Cleanse11.Views.DebloatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Package List -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="🧹 Debloat Windows 11" Style="{StaticResource HeadingAccentStyle}" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Text="Remove pre-installed bloatware and unwanted apps."
                           Style="{StaticResource MutedTextStyle}" Margin="0,0,0,8"/>
                
                <Border Grid.Row="2" Style="{StaticResource DangerBannerStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑️" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Removed apps cannot be restored once image is saved."
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Action Bar -->
                <Border Grid.Row="3" Background="{StaticResource BackgroundBrush}" 
                        CornerRadius="8" Padding="4" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Select All" Command="{Binding SelectAllCommand}" 
                                Padding="16,8" FontSize="12"/>
                        <Button Content="Clear" Command="{Binding ClearAllCommand}" 
                                Margin="6,0,0,0" Padding="16,8" FontSize="12"/>
                        <Border Width="1" Background="{StaticResource BorderBrush}" 
                                Margin="12,4"/>
                        <Button Content="Tiny11 Preset" Command="{Binding Tiny11PresetCommand}" 
                                Style="{StaticResource PrimaryButtonStyle}" 
                                Padding="18,8" FontSize="12"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="4" Style="{StaticResource FadeScrollBarScrollViewer}" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Packages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundLighterBrush}"
                                        CornerRadius="8" Margin="0,0,0,6" Padding="10,8"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" 
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="2" Background="{StaticResource BackgroundBrush}" 
                                                CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Category}"
                                                       Foreground="{StaticResource ForegroundMutedBrush}"
                                                       FontSize="10" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right Panel -->
        <Grid Grid.Column="1" Margin="0,28,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Options -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Options" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,14"/>
                    <CheckBox Content="Remove Microsoft Edge" IsChecked="{Binding RemoveEdge}" Margin="0,0,0,10"/>
                    <CheckBox Content="Remove OneDrive" IsChecked="{Binding RemoveOneDrive}" Margin="0,0,0,10"/>
                    <CheckBox Content="Privacy &amp; Telemetry Fixes" IsChecked="{Binding ApplyOfflineTweaks}" Margin="0,0,0,10"/>
                    <CheckBox Content="Remove Scheduled Tasks" IsChecked="{Binding RemoveScheduledTasks}" Margin="0,0,0,18"/>
                    <Button Content="▶ Apply Debloat" Command="{Binding ApplyCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Padding="20,10" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <!-- Log -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Log" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" Style="{StaticResource FadeScrollBarScrollViewer}" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Log}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                               Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.ColumnSpan="2" Text="{Binding Status}"
                   VerticalAlignment="Bottom" Margin="28,0,28,12"
                   Foreground="{StaticResource ForegroundMutedBrush}"/>
    </Grid>
</UserControl>
