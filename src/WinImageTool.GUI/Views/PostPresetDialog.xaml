<Window x:Class="Cleanse11.Views.PostPresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preset Applied"
        Height="320" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✓ Preset Applied Successfully!" 
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PinkHotBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" x:Name="MessageText"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource ForegroundMutedBrush}"
                   FontSize="14"
                   Margin="0,16"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BuildIsoButton" Content="🔗  Build Bootable ISO" 
                    Padding="24,14" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    FontSize="15"
                    Click="BuildIsoClick"
                    IsDefault="True"
                    Margin="0,0,16,0"/>
            <Button x:Name="ContinueButton" Content="Continue Customizing" 
                    Padding="24,14"
                    Click="ContinueClick"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>