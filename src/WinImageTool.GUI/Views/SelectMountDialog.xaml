<Window x:Class="Cleanse11.Views.SelectMountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Mounted Image"
        Height="350" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a Mounted Image" 
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource PinkHotBrush}"
                   Margin="0,0,0,16"/>

        <ListBox Grid.Row="1" x:Name="MountList"
                 Background="{StaticResource BackgroundLightBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 BorderThickness="1"
                 SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📁" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Path}" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Image}" Foreground="{StaticResource ForegroundMutedBrush}" FontSize="11"/>
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#6BCFAD"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Ready}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="10" Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Ready"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Ready}" Value="False">
                                                <Setter Property="Text" Value="Pending"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Padding="20,10" IsCancel="True" Margin="0,0,10,0"/>
            <Button Content="Connect" Padding="20,10" Style="{StaticResource PrimaryButtonStyle}"
                    Click="ConnectClick" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
