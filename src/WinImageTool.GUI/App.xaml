<Application x:Class="Cleanse11.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Cleanse11.ViewModels"
             xmlns:views="clr-namespace:Cleanse11.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:ImageViewModel}">
                <views:ImageView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DebloatViewModel}">
                <views:DebloatView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ComponentsViewModel}">
                <views:ComponentsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DriversViewModel}">
                <views:DriversView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UpdatesViewModel}">
                <views:UpdatesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TweaksViewModel}">
                <views:TweaksView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UnattendedViewModel}">
                <views:UnattendedView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
